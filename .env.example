# ==========================================
# Speedtar Environment Variables
# ==========================================

# ------------------------------------------
# Frontend Configuration
# ------------------------------------------
NEXT_PUBLIC_API_URL=https://api.hitension.live/api/v1
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ------------------------------------------
# Backend Configuration
# ------------------------------------------
NODE_ENV=production
PORT=5000

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=speedtar
DB_USER=speedtar_user
DB_PASSWORD=change_me_secure_password
DATABASE_URL=postgresql://speedtar_user:change_me_secure_password@postgres:5432/speedtar

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# JWT
JWT_SECRET=change_me_jwt_secret_key_min_32_chars_long
JWT_EXPIRES_IN=7d

# URLs
API_URL=https://api.hitension.live
FRONTEND_URL=https://shop.hitension.live

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_NAME=Speedtar
FROM_EMAIL=noreply@speedtar.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ------------------------------------------
# Development Only
# ------------------------------------------
# ETHEREAL_USER=ethereal_user_for_dev
# ETHEREAL_PASS=ethereal_pass_for_dev
